# --- PostgreSQL (compose: servicio postgres) ---
POSTGRES_USER=metamorph
POSTGRES_PASSWORD=metamorph
POSTGRES_DB=metamorph

DATABASE_URL=postgresql://metamorph:metamorph@localhost:5432/metamorph

# --- RabbitMQ (compose: servicio rabbitmq) ---
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=metamorph.topic
# Management UI: http://localhost:15672

# --- MinIO (compose: servicio minio + minio-init) ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=metamorph-artifacts
MINIO_REGION=us-east-1
# Management UI: http://localhost:9001

# --- Apps ---
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o

PLAYWRIGHT_HEADLESS=true
MAX_CONCURRENT_BROWSERS=2
