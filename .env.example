# --- PostgreSQL (compose: servicio postgres) ---
POSTGRES_USER=metamorph
POSTGRES_PASSWORD=metamorph
POSTGRES_DB=metamorph

DATABASE_URL=postgresql://metamorph:metamorph@localhost:5432/metamorph

# --- RabbitMQ (compose: servicio rabbitmq) ---
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=metamorph.topic
# Management UI: http://localhost:15672

# --- MinIO (compose: servicio minio + minio-init) ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=metamorph-artifacts
MINIO_REGION=us-east-1
# Management UI: http://localhost:9001

# --- API / Web ---
PORT=3001
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
# Browser-accessible MinIO URL for presigned artifact links (defaults to MINIO_ENDPOINT)
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# --- Apps ---
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o
# google/gemini-2.5-flash works with OPENROUTER_USE_JSON_SCHEMA=true after schema fix; avoid leading spaces in the value.
# Abort OpenRouter calls after this many ms (explore_verify with 2 images can stall without it).
OPENROUTER_TIMEOUT_MS=30000
# Use json_schema strict mode only for models that support structured_outputs (opt-in).
OPENROUTER_USE_JSON_SCHEMA=false

PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_LOCALE=es-ES
# Parallel browser jobs (discover, probe, smoke, execute_pair) — default matches four transform families
MAX_CONCURRENT_BROWSERS=4
# Parallel explore graphs (one per transform family by default)
WORKER_LLM_CONCURRENCY=4
