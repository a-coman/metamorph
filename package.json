{
  "name": "metamorph",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.5.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "db:generate": "pnpm --filter @metamorph/api exec prisma generate",
    "db:migrate": "pnpm --filter @metamorph/api exec prisma migrate dev",
    "db:push": "pnpm --filter @metamorph/api exec prisma db push",
    "db:studio": "pnpm --filter @metamorph/api exec prisma studio",
    "inventory:capture": "docker compose --profile workers build inventory-capture && docker compose --profile workers run --rm inventory-capture pnpm --filter @metamorph/inventory capture",
    "validation:batch": "pnpm --filter @metamorph/api-client build && pnpm db:generate && tsx scripts/validation/run-batch.ts",
    "validation:metrics": "pnpm --filter @metamorph/api-client build && pnpm db:generate && tsx scripts/validation/extract-metrics.ts",
    "validation:replay": "pnpm --filter @metamorph/api-client build && tsx scripts/validation/run-replay.ts",
    "validation:summary": "tsx scripts/validation/generate-summary.ts",
    "validation:test": "tsx --test scripts/validation/*.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@metamorph/api-client": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "pg": "^8.21.0",
    "tsx": "^4.22.3",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  }
}
