@article{10.1145/3772722,
author = {Giandomenico, Felicita Di and Masetti, Giulio and Lonetti, Francesca and Bertolino, Antonia},
title = {Using Metamorphic Relations in Redundancy-based Fault/Intrusion Tolerance},
year = {2026},
issue_date = {June 2026},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
volume = {35},
number = {6},
issn = {1049-331X},
url = {https://doi.org/10.1145/3772722},
doi = {10.1145/3772722},
abstract = {Redundancy is widely used as a method for fault and intrusion tolerance. However, if the redundant components lack sufficient diversity, potentially dangerous common mode failures may go undetected. To address this issue, the design diversity approach has been proposed in the literature for decades. In this article, we take an innovative approach to this problem by introducing a broader notion of diversity, which leverages Metamorphic Relations (MRs), i.e., necessary properties that must hold among diverse inputs and diverse outputs. We define two generic categories of MRs that establish data diversity and functional diversity. Furthermore, we elaborate on two corresponding logical architectures, paying particular attention to the necessary conditions for the adjudicator component. Finally, we present an initial evaluation of the proposed architectures, which points out the advantages with respect to their counterparts based on the traditional design diversity method, and discuss future research directions for this novel conceptual approach to redundancy-based fault/intrusion tolerance.},
journal = {ACM Trans. Softw. Eng. Methodol.},
month = may,
articleno = {143},
numpages = {34},
keywords = {Metamorphic Relations, Fault/Intrusion Tolerance, Data diversity, Functional diversity}
}

