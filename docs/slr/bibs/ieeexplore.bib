  number={},
  pages={314-319},
  abstract={In today’s digital era, there is a high demand for reliable and high-quality software, which makes software testing increasingly important. This paper presents a systematic literature review (SLR) of 25 peer-reviewed papers to assess the efficiency of AI in automated software testing, highlighting its advantages, limitations, and evolving trends. It emphasizes core features, such as automated test case generation, self-healing tests, and flaky test detection, while also handling challenges related to the reliability, quality, and integration of the data and model. Despite the evident improvements, future studies are needed to address these challenges and support a deeper integration of the software development lifecycle.},
  keywords={Software testing;Automation;Market research;Data models;Software;Software reliability;Artificial intelligence;Information technology;Systematic literature review;Software development management;Software Testing;Artificial Intelligence;Test Automation},
  doi={10.1109/ICITCOM66635.2025.11265260},
  ISSN={},
  month={Aug},}@INPROCEEDINGS{11273407,
  author={Markov, Ivelin and Sevov, Atanas},
  booktitle={2025 10th International Conference on Energy Efficiency and Agricultural Engineering (EE&AE)}, 
  title={NLP - Bayesian Network Framework - Integrating Scientific Knowledge and Data-Driven Models into Sustainable Turf Management Decision Support System}, 
  year={2025},
  volume={},
  number={},
  pages={01-13},
  abstract={Sustainable turfgrass management requires decisions that account for uncertainty in weather, soil processes, and human practices, yet the underlying scientific knowledge is fragmented across disciplines. This study presents a probabilistic framework that integrates Natural Language Processing (NLP), Machine Learning (ML), and Bayesian Networks (BN) to combine literature-derived causal knowledge with site-specific turfgrass data. Using transformer-based extraction, scientific publications were converted into structured causal relations, which were then merged with empirical observations from IoT sensors, remote sensing, and ML models. A pilot implementation focused on nitrogen fertilization and irrigation. The BN generated site-specific recommendations that reduced irrigation needs by 14.9% while maintaining a 98% probability of acceptable turf quality, and enabled 25% lower nitrogen inputs with an estimated 12% probability of over-fertilization risk. Integrating literature priors with real-time data improved interpretability of ML outputs and allowed explicit intervention queries relevant to management practice. The modular structure enables extension to additional management domains and other environmental systems. The results demonstrate that combining causal knowledge extraction with dynamic probabilistic modelling can support more efficient and transparent decision-making in turfgrass management.},
  keywords={Knowledge engineering;Irrigation;Uncertainty;Soil;Probabilistic logic;Natural language processing;Bayes methods;Sensors;Nitrogen;Remote sensing;Bayesian networks;Natural language processing;Machine learning;Knowledge extraction;Probabilistic modelling;Decision support systems;Turfgrass management;Precision turfgrass;Remote sensing},
  doi={10.1109/EEAE65901.2025.11273407},
  ISSN={},
  month={Nov},}@ARTICLE{11281877,
  author={Zhu, Xiaoyan and Xu, Tianxiang and Lai, Xin and Lian, Xin and Cheng, Hangyu and Wang, Jiayin},
  journal={IEEE Transactions on Software Engineering}, 
  title={Reaching Software Quality for Bioinformatics Applications: How Far Are We?}, 
  year={2026},
  volume={52},
  number={2},
  pages={595-617},
  abstract={With the rapid advancements in medicine, biology, and information technology, their deep integration has given rise to the emerging field of bioinformatics. In this process, high-throughput technologies such as genomics, transcriptomics, and proteomics have generated massive volumes of biological data. The biological significance of these data heavily relies on bioinformatics software for analysis and processing. Therefore, it is crucial for both scientific research and clinical applications to ensure the quality of bioinformatics software and avoiding errors or hidden defects. However, to date, no dedicated study has systematically analyzed the quality of bioinformatics software. We conduct a comprehensive empirical study that aggregates, synthesizes, and analyzes findings from 167 bioinformatics software projects. Following the Preferred Reporting Items for Systematic Review and Meta-Analysis (PRISMA) protocol, we extract and evaluate quality-related data to answer our research questions (RQs). Our analysis reveals several key findings. The quality of bioinformatics software requires significant improvement, with an average defect density approximately 11.8× higher than that of general-purpose software. Additionally, unlike traditional software domains, a considerable proportion of defects in bioinformatics software are related to annotations. These issues can lead developers to overlook potential security vulnerabilities or make incorrect fixes, thereby increasing the cost and complexity of subsequent code maintenance. Based on these findings, we further discuss the challenges faced by bioinformatics software and propose potential solutions. This paper lays a foundation for further research on software quality in the bioinformatics domain and offers actionable insights for researchers and practitioners alike.},
  keywords={Bioinformatics;Software;Software quality;Maintenance engineering;Testing;Source coding;Defect detection;Systematics;Codes;Software algorithms;Bioinformatics software;defect analysis;software quality;static analysis},
  doi={10.1109/TSE.2025.3641225},
  ISSN={1939-3520},
  month={Feb},}@INPROCEEDINGS{10189308,
  author={Dietrich, Jens and Galster, Matthias and Luczak-Roesch, Markus},
  booktitle={2023 IEEE/ACM International Workshop on Equitable Data & Technology (FairWare)}, 
  title={On Retrofitting Provenance for Transparent and Fair Software - Drivers and Challenges}, 
  year={2023},
  volume={},
  number={},
  pages={14-21},
  abstract={There have been ongoing discussions about how to ensure transparency and fairness in software that utilise artificial intelligence (AI). However, transparency and fairness are not limited to AI. Modern (non-AI) software is often constructed in a black box fashion. This means, components and services provide some functionality, but details on how this is achieved are hidden. Common software development and design principles like encapsulation and information hiding promote this. Engineers often only look inside the black boxes when they need to fix problems, e.g., when tracing bugs or vulnerabilities. The demand for transparency has created a need to open those black boxes also to non-engineers. For instance, businesses need to demonstrate regulation compliance, and end users want to understand how systems make fair decisions that affect them. However, adding provenance (i.e., the ability to gather information about data and algorithms used in systems) to existing systems is invasive and costly, and current approaches to collect provenance data are not designed to expose data to end users. We argue that this requires “provenance retrofitting”, i.e., adding provenance capabilities to systems mechanically, and exposing provenance data through standard language and service application programming interfaces (APIs). This could facilitate an infrastructure that supports transparency, which then can in turn be used to create feedback mechanisms for users that in the long term can improve the fairness of software. In this paper we discuss drivers, objectives, key challenges and some possible approaches to provenance retrofitting.},
  keywords={Industries;Encapsulation;Computer bugs;Closed box;Regulation;Artificial intelligence;Standards;provenance;end users;refactoring},
  doi={10.1109/FairWare59297.2023.00007},
  ISSN={},
  month={May},}@ARTICLE{11475480,
  author={Xu, Zhihao and Guo, Shikai and Zhao, Guilin and Wang, Siwen and Ma, Qian and Li, Hui and Zhan, Furui},
  journal={IEEE Transactions on Computer-Aided Design of Integrated Circuits and Systems}, 
  title={Structural Mutation Based Differential Testing for FPGA Logic Synthesis Compilers}, 
  year={2026},
  volume={},
  number={},
  pages={1-1},
  abstract={Field Programmable Gate Arrays (FPGAs) play a crucial role in Electronic Design Automation (EDA) applications, which have been widely used in safety-critical environments, including aerospace, chip manufacturing, and medical devices. A critical stage in FPGA development is logic synthesis, which enables developers to translate their software designs into hardware net lists. However, bugs in FPGA logic synthesis compilers may lead to unexpected behaviors in target hardware net lists, which may cause potential security risks. Therefore, it is critical to detect and repair such bugs in FPGA logic synthesis compilers. While recent testing methods have made progress in automatic bug detection, they remain limited by a fundamental weakness, the generated test cases exhibit minimal timing complexity and structural diversity. To address this challenge, we propose a mutation-based method integrated with Bayesian optimization to detect bugs in FPGA logic synthesis compilers. The method, called SmootHDL, consists with three key components, the Test-program Generation Component (TPG), the Bayesian Diversity Selection Component (BDS), and the Equivalent Test Check Component (ETC). SmootHDL starts with a set of test cases which are called original test cases. To expand the timing test space, the TPG use a control-flow mutation strategy to generate new test cases which is functional equivalent with the original test cases. Furthermore, for increasing diversity of the generated test cases, the BDS combine the Bayesian optimizer to construct a selector based on the control-flow diversity. Finally, the ETC identifies bugs by comparing simulation outputs between original and generated test cases. Since the mutations preserve functional equivalence, functional equivalent test case should have same output. When SmootHDL detects any discrepancy between the outputs, it indicates a potential compiler bug. SmootHDL then reproduces the inconsistent behavior and reports the bug to official developers. We evaluated our method on the mainstream FPGA logic synthesis compilers. Experiments show that SmootHDL can generate more diverse test cases and detect more bugs compared with the latest testing methods for FPGA logic synthesis compilers. Over three months, SmootHDL found 16 bugs, 12 of which were confirmed by official technical support, and 6 have already been fixed.},
  keywords={Radio broadcasting;Frequency modulation;Field programmable gate arrays;Circuits and systems;Integrated circuits;Circuits;Register transfer level;Circuit synthesis;Feedback;High level synthesis;FPGA;Logic Synthesis Compiler;Equivalent Check},
