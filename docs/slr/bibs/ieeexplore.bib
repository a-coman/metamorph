  month={Dec},}@INPROCEEDINGS{11424881,
  author={Zhang, Xiaoyong and Xu, Jianrong and Wang, Sen and Zhu, Jiaxiang and Zheng, Youlun and Wang, Xizheng and Zhang, Xiaochun},
  booktitle={2025 6th International Conference on Computers and Artificial Intelligence Technology (CAIT)}, 
  title={Design and Implementation of a Multi-Agent Testing Platform for Autonomous Driving Simulation}, 
  year={2025},
  volume={},
  number={},
  pages={432-440},
  abstract={High-fidelity simulation is essential for validating autonomous driving systems in diverse and safety-critical conditions, and without the cost and risk of real-world testing. However, existing platforms often lack realistic multi-agent interaction, comprehensive scenario coverage, and standardized closed-loop evaluation. This paper presents a modular multi-agent testing platform for autonomous driving simulation supporting both software-in-the-loop (SIL) and hardware-in-the-loop (HIL) testing. The platform integrates scenario generation, agent behavior modeling, multi-modal sensor simulation, and a four-dimensional evaluation framework covering safety, efficiency, comfort, and robustness. A transformer-based agent model with context-aware embedding, hierarchical temporal windows, and dual-query decoding captures complex inter-agent interactions in dense traffic. Experiments with up to 500 concurrent agents in realistic urban layouts with 0.78 RMM score demonstrate that the platform achieves high scalability and temporal fidelity, while enabling reproducible, statistically rigorous comparisons with rule-based and learningbased baselines.},
  keywords={Scalability;Multimodal sensors;Layout;Transformers;Robustness;Safety;Decoding;Scenario generation;Autonomous vehicles;Testing;Multi-agent simulation;Autonomous driving testing;Scenario generation;Closed-loop evaluation;Software-in-the-loop},
  doi={10.1109/CAIT68620.2025.11424881},
  ISSN={},
  month={Dec},}@ARTICLE{10557561,
  author={Shieh, Shiuhpyng Winston and Lee, Shanhsin and Tsai, Mengru and Chen, Ping-Ching and Lin, Yu-Tung},
  journal={IEEE Reliability Magazine}, 
  title={Generative Threat Variants for Detection Tools Assessment}, 
  year={2024},
  volume={1},
  number={3},
  pages={43-53},
  abstract={Advanced persistent threats (APTs) and ransomware attacks are sophisticated cyberattacks orchestrated by skilled threat actors, capable of persisting undetected within a victim’s network for extended periods. These attacks pose significant challenges to network defense, often resulting in substantial financial and reputational losses for targeted enterprises. Typically involving multiple stages, these attacks leverage highly sophisticated techniques and stealth to effectively impact their targets. Enterprises targeted by such attacks continually strengthen their defenses against these critical cyber threats. Common solutions like antivirus software, extended detection and response (XDR), and security information and event management (SIEM) systems are dedicated to detecting and responding to potential threats. Through early threat identification, effective response strategies, and mitigation efforts, enterprises aim to minimize damage to their networks and sensitive data. However, hackers have become adept at generating threat variants to evade detection through indicators of compromise (IOCs) or indicators of behavior (IOBs) [1]. For instance, software packers and obfuscators can alter a file’s hash value, circumventing IOC-based detection methods. Additionally, hackers may disguise themselves as legitimate browser applications, utilizing domain name system (DNS) or hyper text transfer protocol secure (HTTPS) protocols for command and control (C&C) communication. These evasion techniques often render detection tools ineffective in lab environments, leading to a barrage of false alarms and alert fatigue. Furthermore, investigations by Microsoft and Symantec reveal that hackers can operate undetected for over six months in most APT incidents. This discrepancy underscores the misalignment between existing detection assessment methods and the complex realities of real-world attacks, highlighting a significant gap in current detection capabilities [2].},
  keywords={Computer hacking;Payloads;Emulation;Task analysis;Ransomware;Threat assessment;Cyberattack;Detection algorithms},
  doi={10.1109/MRL.2024.3408710},
  ISSN={2641-8819},
  month={Sep.},}@INPROCEEDINGS{11186079,
  author={Kaynak, Ergün Batuhan and Lami, Mayasah and Moslemi, Sahand and Koyuncu, Anil},
  booktitle={2025 IEEE International Conference on Software Maintenance and Evolution (ICSME)}, 
  title={LLMShot: Reducing Snapshot Testing Maintenance via LLMs}, 
  year={2025},
  volume={},
  number={},
  pages={827-832},
  abstract={Snapshot testing has emerged as a critical technique for UI validation in modern software development, yet it suffers from substantial maintenance overhead due to frequent UI changes causing test failures that require manual inspection to distinguish between genuine regressions and intentional design changes. This manual triage process becomes increasingly burdensome as applications evolve, creating a need for automated analysis solutions. This paper introduces LLMShot, a novel framework that leverages Vision-Language Models (VLMs) to automatically analyze snapshot test failures through semantic classification of UI changes. To evaluate LLMShot's effectiveness, we developed a comprehensive dataset using a feature-rich iOS application with configurable feature flags, creating realistic scenarios that produce authentic snapshot differences representative of real development workflows. Our evaluation using Gemma3 models demonstrates strong classification performance, with the 12 B variant achieving over 84 % recall in identifying failure root causes while the 4 B model offers practical deployment advantages with acceptable performance for continuous integration environments. However, our exploration of selective ignore mechanisms revealed significant limitations in current prompting-based approaches for controllable visual reasoning. LLMShot represents the first automated approach to semantic snapshot test analysis, offering developers structured insights that can substantially reduce manual triage effort and advance toward more intelligent UI testing paradigms.},
  keywords={Software testing;Visualization;Analytical models;Translation;Semantics;Manuals;User interfaces;Cognition;Maintenance;Testing;snapshot testing;software testing;large language models;vision-language models;user interface testing;automated test analysis},
  doi={10.1109/ICSME64153.2025.00087},
  ISSN={2576-3148},
  month={Sep.},}@INPROCEEDINGS{11021218,
