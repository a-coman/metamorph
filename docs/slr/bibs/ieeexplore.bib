  booktitle={2025 Systems and Information Engineering Design Symposium (SIEDS)}, 
  title={AI-Powered Assessment of Wazuh for Obfuscated Threat Detection}, 
  year={2025},
  volume={},
  number={},
  pages={336-341},
  abstract={Malware obfuscation techniques pose a significant challenge to modern security monitoring solutions, enabling malicious code to evade detection and persist within compromised systems. Wazuh, a widely used open-source security monitoring platform, provides real-time threat detection and log analysis, facilitating robust security monitoring. However, its effectiveness against obfuscated malware remains largely unexplored. This research investigates the effectiveness of Wazuh’s logging and alerting capabilities in detecting malware obfuscation techniques. By deploying a controlled sandbox environment with a Wazuh server and Windows 11 agent, we analyze different alerts that are generated during the execution of different code functions and signatures. These alerts, generated by the Wazuh server, are then exported as a CSV and processed by artificial intelligence (AI) models to detect suspicious behaviors in the logs that may require further investigation. The findings of this study aim to provide insight into the Wazuh’s strengths and limitations in detecting obfuscated threats, providing recommendations for enhancing its detection mechanisms and comparing its effective log-generation capabilities for training AI models on predicting what alerts are potential threats and require further attention.},
  keywords={Training;Malware;Threat assessment;Real-time systems;Security;Servers;Monitoring;Surface treatment;Standards;Testing},
  doi={10.1109/SIEDS65500.2025.11021218},
  ISSN={2994-3531},
  month={May},}@ARTICLE{6812226,
  author={Mei, Lijun and Chan, W.K. and Tse, T.H. and Jiang, Bo and Zhai, Ke},
  journal={IEEE Transactions on Services Computing}, 
  title={Preemptive Regression Testingof Workflow-Based Web Services}, 
  year={2015},
  volume={8},
  number={5},
  pages={740-754},
  abstract={An external web service may evolve without prior notification. In the course of the regression testing of a workflow-based web service, existing test case prioritization techniques may only verify the latest service composition using the not-yet-executed test cases, overlooking high-priority test cases that have already been applied to the service composition before the evolution. In this paper, we propose Preemptive Regression Testing  (PRT), an adaptive testing approach to addressing this challenge. Whenever a change in the coverage of any service artifact is detected, PRT recursively preempts the current session of regression test and creates a sub-session of the current test session to assure such lately identified changes in coverage by adjusting the execution priority of the test cases in the test suite. Then, the sub-session will resume the execution from the suspended position. PRT terminates only when each test case in the test suite has been executed at least once without any preemption activated in between any test case executions. The experimental result confirms that testing workflow-based web service in the face of such changes is very challenging; and one of the PRT-enriched techniques shows its potential to overcome the challenge.},
  keywords={Testing;Web services;Electronic mail;Educational institutions;Context;Maintenance engineering;Evolving service composition;adaptive regression testing},
  doi={10.1109/TSC.2014.2322621},
