{
  "name": "@metamorph/inventory",
  "version": "1.0.0",
  "description": "Set-of-Marks page inventory (E1, E2…)",
  "exports": { ".": "./src/index.ts" },
  "scripts": {
    "build": "tsc",
    "build:browser": "esbuild src/infrastructure/playwright/inventory.browser.ts --bundle --platform=browser --format=iife --global-name=__metamorphInventory --outfile=src/infrastructure/playwright/inventory.browser.bundle.js --legal-comments=none --log-level=warning",
    "capture": "pnpm build:browser && tsx scripts/capture-cli.ts",
    "test": "node --import tsx --test $(find src -name '*.test.ts')"
  },
  "type": "module",
  "dependencies": {
    "@metamorph/core": "workspace:*",
    "playwright": "1.60.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "esbuild": "^0.25.12",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
